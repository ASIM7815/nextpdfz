{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.9"
    }
  },
  "rewrites": [
    {
      "source": "/api/protect-pdf",
      "destination": "/api/protect-pdf.py"
    },
    {
      "source": "/api/unlock-pdf",
      "destination": "/api/unlock-pdf.py"
    }
  ]
}
